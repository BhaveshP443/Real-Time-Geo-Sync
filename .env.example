# Geo-Sync Monorepo Environment

# Backend (geo-sync-server)
PORT=4000
# Allowed origin for CORS (Next.js frontend dev server)
CLIENT_ORIGIN=http://localhost:3000

# Frontend (geo-sync-client)
# URL of the Socket.io server
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# If you switch to Google Maps instead of Leaflet, you can add:
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

